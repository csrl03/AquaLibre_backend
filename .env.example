# AquaLibre API — Environment Variables
# Copy this file to .env and fill in the real values

# PostgreSQL (Railway)
# Para desarrollo LOCAL: usar el proxy público de Railway
# Para producción (API desplegada en Railway): usar postgres.railway.internal:5432
DB_HOST=TODO_proxy.rlwy.net
DB_PORT=TODO_puerto_publico
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=TODO_tu_password

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# For dev: use * or your local Expo URL; for prod: use your app's bundle ID scheme
CORS_ORIGINS=*
